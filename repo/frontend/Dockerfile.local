# Local-dev Dockerfile — uses nginx with minimal page for API testing.
# Use only when Docker network is unavailable. CI uses the primary Dockerfile.
FROM nginx:alpine
COPY nginx.conf /etc/nginx/conf.d/default.conf
RUN printf '<!DOCTYPE html><html><head><meta charset="utf-8"><title>TalentOps</title><base href="/"></head><body><h1>TalentOps</h1><p>Local dev mode. API: <a href="/api/health">/api/health</a></p></body></html>' > /usr/share/nginx/html/index.html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
